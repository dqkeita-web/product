<Application
    x:Class="FindAncestor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:global="clr-namespace:FindAncestor.ViewModels"
    StartupUri="/Views/MovieEditorView.xaml">
    <Application.Resources>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <global:PanelModeToVisibilityConverter x:Key="PanelModeToVisibilityConverter" />

        <global:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <global:SelectedFolderHighlightConverter x:Key="SelectedFolderHighlightConverter" />
        <!--  =====================  -->
        <!--  ベース  -->
        <!--  =====================  -->

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        </Style>

        <!--  アニメ  -->
        <Style
            x:Key="AnimatedIconButton"
            BasedOn="{StaticResource IconButton}"
            TargetType="Button">

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  =====================  -->
        <!--  カスタム  -->
        <!--  =====================  -->

        <Style
            x:Key="AddToggleButton"
            BasedOn="{StaticResource AnimatedIconButton}"
            TargetType="Button">

            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />

            <Style.Triggers>

                <DataTrigger Binding="{Binding IsFolderSelectVisible}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="#AAFFFFFF" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.15" ScaleY="1.15" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>

            </Style.Triggers>
        </Style>

        <Style
            x:Key="FolderFloatingButton"
            BasedOn="{StaticResource AnimatedIconButton}"
            TargetType="Button">

            <Setter Property="Opacity" Value="0.65" />
            <Setter Property="Background" Value="#66000000" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="#AA000000" />
                    <Setter Property="BorderBrush" Value="#AAFFFFFF" />
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </Setter.Value>
                    </Setter>
                </Trigger>

            </Style.Triggers>
        </Style>

        <!--  削除  -->
        <Style
            x:Key="DeleteMainButton"
            BasedOn="{StaticResource IconButton}"
            TargetType="Button">

            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Background" Value="#CCFF4444" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Opacity" Value="0.9" />

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.15" ScaleY="1.15" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Application.Resources>
</Application>