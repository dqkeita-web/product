<Window
    x:Class="FindAncestor.Views.MainMenuView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:FindAncestor.Views"
    Title="映像スクロールメーカー"
    Width="1000"
    Height="640"
    Background="#141414"
    WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <views:MainMenuViewModel />
    </Window.DataContext>
    <!--  =========================  -->
    <!--  スタイル  -->
    <!--  =========================  -->
    <Window.Resources>
        <!--  カード  -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#333" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <!--  セクションタイトル  -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#EEEEEE" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <!--  ボタン  -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="12,3" />
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <!--  モダンスライダー  -->
        <Style TargetType="Slider">
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="#C9A24A" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb
                                        Width="16"
                                        Height="16"
                                        Background="White" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="#333" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <!--  =========================  -->
    <!--  レイアウト  -->
    <!--  =========================  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <!--  =========================  -->
        <!--  ヘッダー  -->
        <!--  =========================  -->
        <Border Grid.ColumnSpan="2" Background="#1B1B1B">
            <Grid>
                <TextBlock
                    Margin="20"
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="映像スクロールメーカー" />
                <Border
                    Height="2"
                    VerticalAlignment="Bottom"
                    Background="#C9A24A" />
            </Grid>
        </Border>
        <!--  =========================  -->
        <!--  左パネル（設定）  -->
        <!--  =========================  -->
        <ScrollViewer Grid.Row="1" Grid.Column="0">
            <StackPanel>
                <!--  画面設定  -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="画面設定" />
                        <TextBlock Foreground="White" Text="縦横比" />
                        <ItemsControl ItemsSource="{Binding DisplaySizes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton
                                        Width="90"
                                        Height="36"
                                        Margin="5"
                                        Command="{Binding DataContext.SelectDisplaySizeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding Name}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock
                            Margin="0,10"
                            Foreground="White"
                            Text="{Binding ImageWidth, StringFormat=横幅: {0}px}" />
                        <Slider
                            Maximum="3000"
                            Minimum="1"
                            Value="{Binding ImageWidth}" />
                        <TextBlock
                            Margin="0,10"
                            Foreground="White"
                            Text="{Binding ScrollSpeed, StringFormat=スクロール速度: {0}}" />
                        <Slider
                            Maximum="20"
                            Minimum="-20"
                            Value="{Binding ScrollSpeed}" />
                    </StackPanel>
                </Border>
                <!--  音声設定  -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="音声設定" />
                        <Button
                            Command="{Binding SelectAudioCommand}"
                            Content="音声フォルダ選択"
                            Style="{StaticResource ModernButton}" />
                        <TextBlock
                            Margin="10"
                            HorizontalAlignment="Center"
                            Foreground="White"
                            Text="{Binding CurrentAudioFileName}" />
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <Button
                                Command="{Binding PrevAudioCommand}"
                                Content="⏮"
                                Style="{StaticResource ModernButton}" />
                            <Button
                                Command="{Binding PlayAudioCommand}"
                                Content="▶"
                                Style="{StaticResource ModernButton}" />
                            <Button
                                Command="{Binding StopAudioCommand}"
                                Content="■"
                                Style="{StaticResource ModernButton}" />
                            <Button
                                Command="{Binding NextAudioCommand}"
                                Content="⏭"
                                Style="{StaticResource ModernButton}" />
                        </StackPanel>
                        <CheckBox
                            Margin="10"
                            HorizontalAlignment="Center"
                            Content="ループ再生"
                            Foreground="White"
                            IsChecked="{Binding IsLoopEnabled}" />
                        <TextBlock Foreground="White" Text="音量" />
                        <Slider Maximum="100" Value="{Binding AudioVolume}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <!--  =========================  -->
        <!--  プレビュー  -->
        <!--  =========================  -->
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Margin="10"
            Background="Black"
            CornerRadius="6">
            <!--  Scroll1RowViewを直接表示  -->
            <views:Scroll1RowView />
        </Border>
        <!--  =========================  -->
        <!--  下パネル  -->
        <!--  =========================  -->
        <Border
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="#1A1A1A">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>
                <!--  フォルダ管理  -->
                <StackPanel>
                    <TextBlock Foreground="White" Text="保存先フォルダ" />
                    <ComboBox ItemsSource="{Binding ImageFolders}" SelectedItem="{Binding SelectedImageFolder}" />
                    <TextBlock
                        Margin="0,10,0,0"
                        Foreground="White"
                        Text="保存形式" />
                    <ComboBox ItemsSource="{Binding ImageSaveFormats}" SelectedItem="{Binding SelectedImageSaveFormat}" />
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Width="120"
                            Margin="5"
                            Command="{Binding AddImageToFolderCommand}"
                            Content="画像追加"
                            Style="{StaticResource ModernButton}" />
                        <Button
                            Width="120"
                            Margin="5"
                            Command="{Binding DeleteImagesInFolderCommand}"
                            Content="フォルダ削除"
                            Style="{StaticResource ModernButton}" />
                    </StackPanel>
                </StackPanel>
                <!--  出力  -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <Button
                        Width="200"
                        Height="40"
                        Command="{Binding OpenScroll1RowCommand}"
                        Content="▶ 動画再生"
                        Style="{StaticResource ModernButton}" />
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="5"
                            Command="{Binding ExportPngCommand}"
                            Content="PNG"
                            Style="{StaticResource ModernButton}" />
                        <Button
                            Margin="5"
                            Command="{Binding ExportJpegCommand}"
                            Content="JPEG"
                            Style="{StaticResource ModernButton}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>