<Window
    x:Class="FindAncestor.Views.ShowMovie"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:FindAncestor.Views"
    xmlns:viewModels="clr-namespace:FindAncestor.ViewModels"
    Title="1行スクロール"
    Width="1280"
    Height="720"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <!--  16:9 の場合 → AspectRatio="1.777778"  -->

        <!--  3:2 の場合 → AspectRatio="1.5"  -->

        <local:ScrollingPreviewView AspectRatio="1.333333" ImageHeight="300" />
    </Grid>
</Window>